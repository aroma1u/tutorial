   ],
   "source": [
    "n = float(input(\"Enter a number: \"))\n",
    "guess = n / 2\n",
    "\n",
    "for _ in range(20):\n",
    "    guess = (guess + n / guess) / 2\n",
    "\n",
    "print(\"Square root:\", guess)\n"
   ]
